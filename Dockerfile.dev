# ===========================================================================
# WildArc — Development Dockerfile (used by docker-compose.yml)
# ===========================================================================
# Two build targets:
#   - api:      Node.js + ts-node-dev for hot-reloading backend
#   - frontend: Node.js + Vite dev server for hot-reloading frontend

FROM node:22-alpine AS base
WORKDIR /app

# ---- API dev target ----
FROM base AS api
COPY package*.json ./
RUN npm install
COPY tsconfig.json ./
COPY src/ ./src/
# ts-node-dev is run via the command in docker-compose, not here
EXPOSE 3000

# ---- Frontend dev target ----
FROM base AS frontend
WORKDIR /app/frontend
COPY frontend/package*.json ./
RUN npm install
COPY frontend/ ./
EXPOSE 5173
